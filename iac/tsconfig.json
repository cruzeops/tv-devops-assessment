{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": ".",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["main.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", ".gen", "cdktf.out"]
}